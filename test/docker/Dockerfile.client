FROM alpine:3.19

RUN apk add --no-cache \
    openssh-client \
    screen \
    bash \
    coreutils \
    expect \
    iproute2 \
    iptables \
    grep \
    sed

# Create test user
RUN adduser -D -s /bin/bash testuser \
    && mkdir -p /home/testuser/.ssh \
    && chown -R testuser:testuser /home/testuser/.ssh \
    && chmod 700 /home/testuser/.ssh

# Generate SSH key for testuser
RUN su - testuser -c "ssh-keygen -t ed25519 -f /home/testuser/.ssh/id_ed25519 -N ''"

# Disable strict host key checking for testing
RUN echo "Host *" > /home/testuser/.ssh/config \
    && echo "    StrictHostKeyChecking no" >> /home/testuser/.ssh/config \
    && echo "    UserKnownHostsFile /dev/null" >> /home/testuser/.ssh/config \
    && echo "    LogLevel ERROR" >> /home/testuser/.ssh/config \
    && chown testuser:testuser /home/testuser/.ssh/config \
    && chmod 600 /home/testuser/.ssh/config

# Copy bssh script
COPY bssh /usr/local/bin/bssh
RUN chmod +x /usr/local/bin/bssh

# Copy test scripts
COPY test/docker/scripts /home/testuser/tests
RUN chown -R testuser:testuser /home/testuser/tests \
    && chmod +x /home/testuser/tests/*.sh

WORKDIR /home/testuser

# Keep container running
CMD ["tail", "-f", "/dev/null"]
